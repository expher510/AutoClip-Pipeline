{
  "manifest_version": 3,
  "name": "YouTube Video Sender",
  "version": "1.2.0",
  "description": "ابعت بيانات اي فيديو يوتيوب على Webhook بضغطة زرار كلبنج",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "cookies"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.google.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
